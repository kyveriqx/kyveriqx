# Public app URL (used by middleware for host parsing in dev)
NEXT_PUBLIC_ROOT_DOMAIN=kyveriqx.com

# Supabase (Step 4 — Architecture §8.4)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Trigger.dev (Step 5 — Architecture §8.5)
TRIGGER_SECRET_KEY=
TRIGGER_PROJECT_REF=

# Razorpay (Step 6 — Architecture §8.6)
# Test-mode keys for local/preview; swap to rzp_live_* in production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# The browser also needs the public key to open Razorpay Checkout.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# One Razorpay Plan per tool — created in the Razorpay dashboard, priced
# in INR per `tools.price`. The slug suffix matches `tools.slug` upper-cased
# (resolved by planIdForSlug() in core/lib/razorpay.ts).
RAZORPAY_PLAN_GSTLEDGERRECO=
RAZORPAY_PLAN_BANKLEDGERRECO=
RAZORPAY_PLAN_ORGLEDGERRECO=
RAZORPAY_PLAN_CUSTPORTAL=
RAZORPAY_PLAN_CALLINGTOOL=
RAZORPAY_PLAN_WHATSAPPCAMPAIGN=
RAZORPAY_PLAN_EMAILCAMPAIGN=

# emailcampaign — at-rest encryption key for saved SMTP passwords AND OAuth
# refresh tokens (32 bytes, base64). Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Must also be synced to the Trigger.dev worker (see trigger.config.ts).
SMTP_ENCRYPTION_KEY=

# emailcampaign — "Connect Microsoft" OAuth (Microsoft Graph sendMail).
# Register a multitenant app in Microsoft Entra with delegated Graph
# permissions Mail.Send + offline_access + openid/email/profile + User.Read,
# and redirect URI <tool-origin>/api/oauth/microsoft/callback. The Trigger.dev
# worker needs both too (it refreshes the access token at send time).
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=

# Anthropic (for AI tools — Architecture §3)
ANTHROPIC_API_KEY=
